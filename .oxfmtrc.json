{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "apps/web/src/routeTree.gen.ts",
    ".opencode/skills/**"
  ],
  "sortImports": {
    "customGroups": [
      {
        "groupName": "tanstack",
        "elementNamePattern": ["@tanstack/**"]
      },
      {
        "groupName": "stitch",
        "elementNamePattern": ["@stitch/**"]
      }
    ],
    "groups": [
      ["value-builtin", "value-external"],
      "tanstack",
      "stitch",
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  }
}
