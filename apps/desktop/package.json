{
  "name": "@stitch/desktop",
  "version": "0.6.10",
  "private": true,
  "description": "Stitch desktop application",
  "author": "Stitch",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:web": "bun run --filter @stitch/web build",
    "build:sidecar": "bun run --filter @stitch/server build",
    "build:audio-native": "bun ../../scripts/build-audio-native.mjs",
    "build:meeting-detection": "bun ../../scripts/build-meeting-detection.mjs",
    "package": "bun run build:web && bun run build && bun run build:sidecar && bun run build:audio-native && bun run build:meeting-detection && electron-builder --config electron-builder.config.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stitch/audio-capture": "workspace:*",
    "@stitch/meeting-detection": "workspace:*",
    "@stitch/shared": "workspace:*",
    "@types/ws": "^8.18.1",
    "electron-updater": "^6.8.3",
    "tree-kill": "1.2.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "25.5.0",
    "electron": "41.0.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "typescript": "catalog:"
  }
}
