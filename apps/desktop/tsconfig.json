{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun", "node"],
    "esModuleInterop": true,
    "strict": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*", "electron.vite.config.ts", "electron-builder.config.ts"]
}
