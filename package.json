{
  "name": "stitch",
  "private": true,
  "workspaces": [
    "apps/*",
    "registries/*",
    "packages/*",
    "connectors/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@stitch/web --filter=@stitch/desktop --filter=@stitch/server",
    "audio-native:build": "node scripts/build-audio-native.mjs",
    "format:changed": "tsx scripts/format-changed.ts",
    "format:changed:check": "tsx scripts/format-changed.ts --check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "knip": "knip",
    "check": "tsx scripts/check.ts",
    "website:build": "bun run --cwd apps/website build"
  },
  "devDependencies": {
    "knip": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "^0.16.0",
    "tsx": "^4.21.0",
    "turbo": "latest"
  },
  "packageManager": "bun@1.3.8",
  "catalog": {
    "typescript": "latest",
    "@types/node": "latest",
    "zod": "4.3.6"
  },
  "catalogs": {
    "testing": {
      "vitest": "latest"
    },
    "ai": {
      "ai": "6.0.116",
      "@ai-sdk/provider": "3.0.8",
      "@ai-sdk/amazon-bedrock": "4.0.77",
      "@ai-sdk/anthropic": "3.0.58",
      "@ai-sdk/google": "3.0.43",
      "@ai-sdk/google-vertex": "4.0.80",
      "@ai-sdk/openai": "3.0.41",
      "@ai-sdk/openai-compatible": "2.0.41",
      "@ai-sdk/mcp": "1.0.25",
      "@openrouter/ai-sdk-provider": "2.3.0"
    }
  }
}
