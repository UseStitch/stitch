{
  "name": "stitch",
  "private": true,
  "workspaces": [
    "apps/*",
    "registries/*",
    "packages/*",
    "connectors/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@stitch/web --filter=@stitch/desktop",
    "audio-native:build": "node scripts/build-audio-native.mjs",
    "format:changed": "bun run scripts/format-changed.ts",
    "format:changed:check": "bun run scripts/format-changed.ts --check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "knip": "knip",
    "check": "bun run scripts/check.ts",
    "website:build": "bun run --cwd apps/website build",
    "website:dev": "bun run --cwd apps/website dev"
  },
  "devDependencies": {
    "knip": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "^0.16.0",
    "turbo": "latest"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "typescript": "latest",
    "@types/bun": "latest",
    "zod": "4.3.6"
  },
  "catalogs": {
    "ai": {
      "ai": "6.0.116",
      "@ai-sdk/provider": "3.0.10",
      "@ai-sdk/amazon-bedrock": "4.0.120",
      "@ai-sdk/anthropic": "3.0.85",
      "@ai-sdk/google": "3.0.83",
      "@ai-sdk/google-vertex": "4.0.148",
      "@ai-sdk/openai": "3.0.74",
      "@ai-sdk/openai-compatible": "2.0.51",
      "@openrouter/ai-sdk-provider": "2.9.1"
    }
  }
}
