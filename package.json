{
  "name": "openwork",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "typescript": "latest",
    "@types/bun": "latest",
    "zod": "4.3.6"
  },
  "catalogs": {
    "testing": {
      "vitest": "latest"
    }
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "oxfmt write .",
    "format:check": "oxfmt check .",
    "typecheck": "turbo typecheck",
    "knip": "knip",
    "check": "bun run scripts/check.ts"
  },
  "devDependencies": {
    "turbo": "latest",
    "oxlint": "latest",
    "oxfmt": "latest",
    "knip": "latest"
  }
}