{
  "name": "openwork",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "typescript": "latest",
    "@types/bun": "latest",
    "zod": "4.3.6"
  },
  "catalogs": {
    "testing": {
      "vitest": "latest"
    },
    "ai": {
      "ai": "6.0.116",
      "@ai-sdk/amazon-bedrock": "4.0.77",
      "@ai-sdk/anthropic": "3.0.58",
      "@ai-sdk/google": "3.0.43",
      "@ai-sdk/google-vertex": "4.0.80",
      "@ai-sdk/openai": "3.0.41",
      "@ai-sdk/openai-compatible": "2.0.35",
      "@openrouter/ai-sdk-provider": "2.3.0"
    }
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "oxfmt write .",
    "format:check": "oxfmt check .",
    "typecheck": "turbo typecheck",
    "knip": "knip",
    "check": "bun run scripts/check.ts"
  },
  "devDependencies": {
    "turbo": "latest",
    "oxlint": "latest",
    "oxfmt": "latest",
    "knip": "latest"
  }
}