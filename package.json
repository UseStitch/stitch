{
  "name": "stitch",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@stitch/web --filter=@stitch/desktop",
    "format": "oxfmt write .",
    "format:check": "oxfmt check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "knip": "knip",
    "check": "bun run scripts/check.ts",
    "release:version": "bun run scripts/release/version.ts",
    "release:bump": "bun run scripts/release/bump.ts",
    "release:notes": "bun run scripts/release/notes.ts",
    "release:request": "bun run scripts/release/request.ts",
    "release:tag": "bun run scripts/release/tag.ts"
  },
  "devDependencies": {
    "knip": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "^0.16.0",
    "turbo": "latest"
  },
  "packageManager": "bun@1.3.8",
  "catalog": {
    "typescript": "latest",
    "@types/bun": "latest",
    "zod": "4.3.6"
  },
  "catalogs": {
    "testing": {
      "vitest": "latest"
    },
    "ai": {
      "ai": "6.0.116",
      "@ai-sdk/provider": "3.0.8",
      "@ai-sdk/amazon-bedrock": "4.0.77",
      "@ai-sdk/anthropic": "3.0.58",
      "@ai-sdk/google": "3.0.43",
      "@ai-sdk/google-vertex": "4.0.80",
      "@ai-sdk/openai": "3.0.41",
      "@ai-sdk/mcp": "1.0.25",
      "@openrouter/ai-sdk-provider": "2.3.0"
    }
  }
}
